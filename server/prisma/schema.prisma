generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User{
    id String @id @default(uuid())
    first_name String
    last_name String
    email String @unique
    password String
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@map("users")
}